void TabDesk::sendWindDataToServerOld(uint64_t hour, uint64_t tick, float speed, uint16_t direction)
{
    static bool open = false;
    if (WiFi.status() == WL_CONNECTED)
    {
        if (!open || !http.connected())
        {
            open = true;
            // Set the root certificate for the server
            // client.setCACert(root_ca);
            client.setInsecure();
            // Specify the URL
            String url = "https://servert.thilenius.com/ultimeterUpdate";
            http.begin(client, url);
        }
        // Prepare the payload
        String payload = "{\"hour\":" + String(hour) + ",\"tick\":" + String(tick) + ",\"speed\":" + String(speed) + ",\"direction\":" + String(direction) + "}";

        // Specify content-type header
        http.addHeader("Content-Type", "application/json");

        // Send the POST request
        int httpResponseCode = http.POST(payload);

        // Check the response code
        if (httpResponseCode > 0)
        {
            String responseBody = http.getString();
            Serial0.println("Response body:");
            Serial0.println(responseBody);
        }
        else
        {
            Serial0.print("Error code: ");
            Serial0.println(httpResponseCode);
        }

        // http.end(); // Free the resources
    }
    else
    {
        Serial0.println("WiFi Disconnected");
        return;
    }
}

void sendWindDataTask(void *parameter)
{
    WindData *data = (WindData *)parameter;

    // Prepare the payload
    String payload = "{\"hour\":" + String(data->hour) + ",\"tick\":" + String(data->tick) + ",\"speed\":" + String(data->speed) + ",\"direction\":" + String(data->direction) + "}";

    // Specify content-type header
    data->http->addHeader("Content-Type", "application/json");

    // Send the POST request
    int httpResponseCode = data->http->POST(payload);

    // Check the response code
    if (httpResponseCode > 0)
    {
        String responseBody = data->http->getString();
        Serial0.println("Response body:");
        Serial0.println(responseBody);
    }
    else
    {
        Serial0.print("Error code: ");
        Serial0.println(httpResponseCode);
    }

    // Free the allocated memory
    delete data;
    data->http->end(); // Free the resources
    // Delete the task when done
    vTaskDelete(NULL);
}

void TabDesk::sendWindDataToServer(uint64_t hour, uint64_t tick, float speed, uint16_t direction)
{
    lastComm = millis();
    static bool open = false;
    if (WiFi.status() == WL_CONNECTED)
    {

        client.setInsecure();
        String url = "https://servert.thilenius.com/ultimeterUpdate";
        http.begin(client, url);
        WindData *data = new WindData;
        data->hour = hour;
        data->tick = tick;
        data->speed = speed;
        data->direction = direction;
        data->http = &http;

        // Create a new task to send the data
        xTaskCreate(
            sendWindDataTask, // Task function
            "SendWindData",   // Task name
            8192,             // Stack size (in words)
            data,             // Task input parameter
            1,                // Priority of the task
            NULL              // Task handle
        );
    }
}

void sendWindPingTask(void *parameter)
{
    PingData *data = (PingData *)parameter;
    int httpResponseCode = data->http->GET();

    // Check the response code
    if (httpResponseCode > 0)
    {
        String responseBody = data->http->getString();
        Serial0.println("Response body:");
        Serial0.println(responseBody);
    }
    else
    {
        Serial0.print("Error code: ");
        Serial0.println(httpResponseCode);
    }

    // Free the allocated memory
    delete data;
    data->http->end(); // Free the resources
    // Delete the task when done
    vTaskDelete(NULL);
}

void TabDesk::pingServer()
{
    // run every three minutes if nothing else has happened, and on startup
    if (lastComm > 0 && millis() - lastComm < 180000)
        return;
    lastComm = millis();
    static bool open = false;
    if (WiFi.status() == WL_CONNECTED)
    {
        client.setInsecure();
        client.setCertificate(ca_cert);
        String url = "https://servert.thilenius.com/ultimeterPing";
        http.begin(client, url);
        PingData *data = new PingData;
        data->http = &http;

        // Create a new task to send the data
        xTaskCreate(
            sendWindPingTask, // Task function
            "SendWindPing",   // Task name
            8192,             // Stack size (in words)
            data,             // Task input parameter
            1,                // Priority of the task
            NULL              // Task handle
        );
    }
}

